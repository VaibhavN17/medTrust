## Example backend environment variables
# Replace PASSWORD and host/dbname with your Neon details. Remove any `channel_binding` entries.
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-dawn-shape-aqtbgrba-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=verify-full

# Other env variables used by the app (examples)
NODE_ENV=development
JWT_SECRET=your_jwt_secret
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# === IMAGE UPLOAD PROVIDER ===
# Options: 'cloudinary', 's3', or 'local'
UPLOAD_PROVIDER=cloudinary

# Cloudinary Configuration (FREE TIER)
# Sign up at https://cloudinary.com/users/register/free
# Preferred format:
CLOUDINARY_URL=cloudinary://893533814836148:MGQFsTDhExOQhFodEb3AACd7mOg@dkbobpqaz
# Or set the individual values instead:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# AWS S3 Configuration (Optional - if using S3 instead)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_BUCKET_NAME=your_bucket_name

# Public API URL (for image URLs in responses)
PUBLIC_API_URL=http://localhost:5000
