# ── Server ──────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Database ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=medtrust

# ── JWT ──────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# ── Uploads ─────────────────────────────────────
# local: saves files under backend/uploads (recommended for development)
# s3:    uploads files to AWS S3 using the credentials below
UPLOAD_PROVIDER=local
PUBLIC_API_URL=http://localhost:5000

# ── AWS S3 ────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=medtrust-docs

# ── Razorpay ──────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# ── Email (SMTP) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@medtrust.in
SMTP_PASS=your_app_password
EMAIL_FROM="MedTrust <noreply@medtrust.in>"
